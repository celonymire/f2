---
import Navbar from "../components/Navbar.astro";

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Products</title>
  </head>
  <body>
    <header>
      <h1>Products Page</h1>
      <Navbar />
    </header>

    <main>
      <section>
        <h2>Featured Products</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras mattis
          consectetur purus sit amet fermentum.
        </p>
      </section>

      <section>
        <h2>List</h2>
        <ul>
          <li>Product Lorem - dolor sit amet.</li>
          <li>Product Ipsum - nibh ultricies vehicula.</li>
          <li>Product Dolor - porta felis euismod.</li>
          <li>Product Amet - cursus magna.</li>
        </ul>
      </section>
    </main>

    <style>
      body {
        font-family: sans-serif;
        line-height: 1.5;
        margin: 0;
        padding: 1.5rem;
      }

      header {
        margin-bottom: 1.5rem;
      }

      nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      main {
        display: grid;
        gap: 1.25rem;
      }
    </style>
  </body>
</html>
