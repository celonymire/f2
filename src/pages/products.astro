---
import Navbar from "../components/Navbar.astro";
import snapshotData from "../data/products.snapshot.json";
import { ProductSnapshotSchema } from "../data/schemas";

const snapshot = ProductSnapshotSchema.parse(snapshotData);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Products</title>
  </head>
  <body>
    <header>
      <h1>Products Page</h1>
      <Navbar />
    </header>

    <main>
      <p>Snapshot generated at: {snapshot.generatedAt || "unknown"}</p>

      {
        snapshot.products.length === 0 ? (
          <p>No products found.</p>
        ) : (
          <ul>
            {snapshot.products.map((product) => (
              <li>
                {product.imageUrl ? (
                  <img
                    src={product.imageUrl}
                    alt={product.title}
                    loading="lazy"
                  />
                ) : (
                  <span>No image</span>
                )}
                <br />
                {product.title} | {product.brand} | {product.category} |{" "}
                {product.currency} {product.price}| {product.availability} |
                source: {product.source}
              </li>
            ))}
          </ul>
        )
      }
    </main>
  </body>
</html>
