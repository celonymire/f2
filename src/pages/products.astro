---
import Navbar from "../components/Navbar.astro";

import { readFile } from "node:fs/promises";

type Product = {
  id: string;
  source: string;
  sourceProductId: string;
  title: string;
  brand: string;
  category: string;
  price: number;
  currency: string;
  availability: string;
  imageUrl: string;
  productUrl: string;
  fetchedAt: string;
};

type ProductSnapshot = {
  generatedAt: string;
  products: Product[];
};

const snapshotPath = new URL("../../public/data/products.snapshot.json", import.meta.url);
let snapshot: ProductSnapshot = {
  generatedAt: "",
  products: [],
};

try {
  const fileContent = await readFile(snapshotPath, "utf8");
  const parsed = JSON.parse(fileContent) as Partial<ProductSnapshot>;
  snapshot = {
    generatedAt: parsed.generatedAt ?? "",
    products: Array.isArray(parsed.products) ? parsed.products : [],
  };
} catch {
  // Keep page rendering even if snapshot is unavailable.
}

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Products</title>
  </head>
  <body>
    <header>
      <h1>Products Page</h1>
      <Navbar />
    </header>

    <main>
      <p>Snapshot generated at: {snapshot.generatedAt || "unknown"}</p>

      {
        snapshot.products.length === 0 ? (
          <p>No products found.</p>
        ) : (
          <ul>
            {
              snapshot.products.map((product) => (
                <li>
                  {
                    product.imageUrl ? (
                      <img src={product.imageUrl} alt={product.title} loading="lazy" />
                    ) : (
                      <span>No image</span>
                    )
                  }
                  <br />
                  {product.title} | {product.brand} | {product.category} | {product.currency} {product.price}
                  | {product.availability} | source: {product.source}
                </li>
              ))
            }
          </ul>
        )
      }
    </main>
  </body>
</html>
