---
import Navbar from "../components/Navbar.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Calculator</title>
  </head>
  <body>
    <header>
      <h1>Calculator Page</h1>
      <Navbar />
    </header>

    <main>
      <section>
        <h2>Pace Calculator</h2>
        <p>
          Enter a distance in meters and a time in hh:mm:ss to calculate pace
          per mile and pace per kilometer.
        </p>
      </section>

      <section>
        <h2>Inputs</h2>
        <form>
          <label>
            Common running distance
            <select id="distance-presets">
              <option value="400">400 m</option>
              <option value="800">800 m</option>
              <option value="1500">1500 m</option>
              <option value="3000">3000 m</option>
              <option value="5000">5K / 5000 m</option>
              <option value="10000">10K / 10000 m</option>
              <option value="21098.75">Half marathon / 21.1 km</option>
              <option value="42195">Marathon / 42.2 km</option>
              <option value="custom">Custom</option>
            </select>
          </label>
          <div id="custom-distance-field" hidden>
            <label>
              Custom distance (meters)
              <input
                id="distance"
                type="number"
                min="0"
                step="any"
                value="1000"
              />
            </label>
          </div>
          <div class="time-grid" aria-label="Time input">
            <label>
              Hours
              <input
                id="hours"
                type="number"
                min="0"
                max="59"
                step="1"
                value="1"
              />
            </label>
            <label>
              Minutes
              <input
                id="minutes"
                type="number"
                min="0"
                max="59"
                step="1"
                value="0"
              />
            </label>
            <label>
              Seconds
              <input
                id="seconds"
                type="number"
                min="0"
                max="59"
                step="1"
                value="0"
              />
            </label>
          </div>
          <div class="demographic-grid" aria-label="Demographic input">
            <label>
              Gender
              <select id="gender">
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </label>
            <label>
              Age group
              <select id="age-group">
                <option value="10">10</option>
                <option value="15">15</option>
                <option value="20">20</option>
                <option value="25">25</option>
                <option value="30" selected>30</option>
                <option value="35">35</option>
                <option value="40">40</option>
                <option value="45">45</option>
                <option value="50">50</option>
                <option value="55">55</option>
                <option value="60">60</option>
                <option value="65">65</option>
                <option value="70">70</option>
                <option value="75">75</option>
                <option value="80">80</option>
                <option value="85">85</option>
                <option value="90">90</option>
              </select>
            </label>
          </div>
        </form>
      </section>

      <section>
        <h2>Results</h2>
        <dl class="results">
          <div>
            <dt>Pace per mile</dt>
            <dd id="pace-per-mile">00:00:00 / mi</dd>
          </div>
          <div>
            <dt>Pace per kilometer</dt>
            <dd id="pace-per-kilometer">00:00:00 / km</dd>
          </div>
          <div>
            <dt>Time</dt>
            <dd id="formatted-time">00:00:00</dd>
          </div>
          <div>
            <dt>Race rank</dt>
            <dd id="race-rank">Loading rank data...</dd>
          </div>
          <div>
            <dt>VDOT score</dt>
            <dd id="vdot-score">N/A</dd>
          </div>
          <div>
            <dt>VDOT level</dt>
            <dd id="vdot-level">N/A</dd>
          </div>
        </dl>
      </section>

      <section class="benchmarks" aria-labelledby="benchmarks-heading">
        <h2 id="benchmarks-heading">Average Race Time Benchmarks</h2>
        <p>
          Compare your result against average finish times by age group and
          gender. Select a distance to view benchmark times.
        </p>

        <div class="benchmark-controls">
          <label>
            View
            <select id="benchmark-view" aria-label="Benchmark view">
              <option value="chart" selected>Chart</option>
              <option value="table">Table</option>
            </select>
          </label>
          <label>
            Distance
            <select id="benchmark-distance" aria-label="Benchmark distance">
              <option value="5k" selected>5K</option>
              <option value="10k">10K</option>
              <option value="half-marathon">Half Marathon</option>
              <option value="marathon">Marathon</option>
            </select>
          </label>
          <label>
            Rank
            <select id="benchmark-rank" aria-label="Benchmark rank">
              <option value="all" selected>All ranks</option>
              <option value="beginner">Beginner</option>
              <option value="novice">Novice</option>
              <option value="intermediate">Intermediate</option>
              <option value="advanced">Advanced</option>
              <option value="elite">Elite</option>
            </select>
          </label>
          <label>
            Gender display
            <select id="benchmark-gender" aria-label="Benchmark gender">
              <option value="all" selected>All</option>
              <option value="male">Men only</option>
              <option value="female">Women only</option>
            </select>
          </label>
        </div>

        <div id="benchmark-chart-wrap" class="benchmark-chart-wrap">
          <p id="benchmark-chart-summary" class="benchmark-chart-summary"></p>
          <div class="benchmark-chart-scroller">
            <canvas
              id="benchmark-chart"
              class="benchmark-chart"
              width="720"
              height="360"
              role="img"
              aria-label="Benchmark pace chart by age"></canvas>
          </div>
        </div>

        <div id="benchmark-table-wrap" class="benchmark-table-wrap" hidden>
          <table class="benchmark-table" aria-describedby="benchmark-note">
            <caption id="benchmark-caption">
              Average finish times by age group and gender
            </caption>
            <thead>
              <tr>
                <th scope="col">Age Group</th>
                <th scope="col">Men</th>
                <th scope="col">Women</th>
              </tr>
            </thead>
            <tbody id="benchmark-body"></tbody>
          </table>
        </div>

        <p id="benchmark-note" class="benchmark-note">
          Source: RunningLevel running standards by age and ability, retrieved
          April 17, 2026. Select rank, distance, and gender to compare pace
          times by group; values may vary by event, region, and year.
        </p>
      </section>

      <section
        class="vdot-benchmarks"
        aria-labelledby="vdot-benchmarks-heading"
      >
        <h2 id="vdot-benchmarks-heading">VDOT Metric Table</h2>
        <p>
          This reference table uses Marathon Handbook's VDOT categories to show
          how the score maps to broad training and performance levels.
        </p>

        <div class="vdot-table-wrap">
          <table class="vdot-table" aria-describedby="vdot-note">
            <caption id="vdot-caption">
              VDOT score categories by runner level and gender-specific targets
            </caption>
            <thead>
              <tr>
                <th scope="col">Level</th>
                <th scope="col">Men</th>
                <th scope="col">Women</th>
                <th scope="col">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">Beginner</th>
                <td>35</td>
                <td>31.4</td>
                <td>New to structured running; building aerobic base</td>
              </tr>
              <tr>
                <th scope="row">Novice</th>
                <td>40</td>
                <td>35.8</td>
                <td>Running consistently with improving pace control</td>
              </tr>
              <tr>
                <th scope="row">Intermediate Recreational</th>
                <td>50</td>
                <td>44.6</td>
                <td>Solid club-level fitness and endurance</td>
              </tr>
              <tr>
                <th scope="row">High-Level Recreational</th>
                <td>60</td>
                <td>53.4</td>
                <td>Strong age-group competitor with fast times</td>
              </tr>
              <tr>
                <th scope="row">Sub-Elite</th>
                <td>70</td>
                <td>62.2</td>
                <td>Regional-caliber performance and training volume</td>
              </tr>
              <tr>
                <th scope="row">National Class</th>
                <td>75</td>
                <td>66.6</td>
                <td>Nationally competitive standard in many events</td>
              </tr>
              <tr>
                <th scope="row">Elite</th>
                <td>80</td>
                <td>71</td>
                <td
                  >International-level potential with exceptional race speed</td
                >
              </tr>
            </tbody>
          </table>
        </div>

        <p id="vdot-note" class="vdot-note">
          Source: Marathon Handbook. VDOT values are guideline references used
          to estimate aerobic capacity and compare fitness across different race
          distances and times.
        </p>
      </section>
    </main>

    <script src="../scripts/calculator.ts"></script>

    <style>
      body {
        font-family: sans-serif;
        line-height: 1.5;
        margin: 0;
        padding: 1.5rem;
      }

      header {
        margin-bottom: 1.5rem;
      }

      nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      main {
        display: grid;
        gap: 1.25rem;
      }

      form {
        display: grid;
        gap: 0.75rem;
        max-width: 32rem;
      }

      label {
        display: grid;
        gap: 0.35rem;
      }

      select {
        width: 100%;
        box-sizing: border-box;
        padding: 0.5rem;
      }

      .time-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .demographic-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .results {
        display: grid;
        gap: 1rem;
        margin: 0;
      }

      .results div {
        display: grid;
        gap: 0.25rem;
      }

      .benchmarks {
        display: grid;
        gap: 0.9rem;
      }

      .benchmarks p {
        margin: 0;
      }

      .benchmark-controls {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: end;
      }

      .benchmark-controls label {
        flex: 1 1 12rem;
      }

      .benchmark-chart-wrap {
        display: grid;
        gap: 0.75rem;
      }

      .benchmark-chart-wrap[hidden],
      .benchmark-table-wrap[hidden] {
        display: none;
      }

      .benchmark-chart-summary {
        font-size: 0.95rem;
        color: #333;
      }

      .benchmark-chart-scroller {
        overflow-x: auto;
      }

      .benchmark-chart {
        display: block;
        min-width: 44rem;
        width: 100%;
        height: auto;
        background: #fff;
      }

      .benchmark-table-wrap {
        overflow-x: auto;
      }

      .benchmark-table {
        border-collapse: collapse;
        min-width: 28rem;
        width: 100%;
      }

      .benchmark-table caption {
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-align: left;
      }

      .benchmark-table :global(th),
      .benchmark-table :global(td) {
        border: 1px solid #d0d0d0;
        padding: 0.5rem;
        text-align: center;
      }

      .benchmark-table :global(thead th) {
        background: #f4f4f4;
      }

      .benchmark-note {
        color: #333;
        font-size: 0.95rem;
      }

      .vdot-benchmarks {
        display: grid;
        gap: 0.9rem;
      }

      .vdot-benchmarks p {
        margin: 0;
      }

      .vdot-table-wrap {
        overflow-x: auto;
      }

      .vdot-table {
        border-collapse: collapse;
        min-width: 28rem;
        width: 100%;
      }

      .vdot-table caption {
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-align: left;
      }

      .vdot-table :global(th),
      .vdot-table :global(td) {
        border: 1px solid #d0d0d0;
        padding: 0.5rem;
        text-align: center;
      }

      .vdot-table :global(thead th) {
        background: #f4f4f4;
      }

      .vdot-table :global(th[scope="row"]) {
        text-align: left;
      }

      .vdot-note {
        color: #333;
        font-size: 0.95rem;
      }

      dt {
        font-size: 0.9rem;
        font-weight: 700;
      }

      dd {
        margin: 0;
        font-size: 1.4rem;
        font-weight: 700;
      }

      input {
        width: 100%;
        box-sizing: border-box;
      }

      input,
      button {
        padding: 0.5rem;
      }

      @media (max-width: 640px) {
        .time-grid {
          grid-template-columns: 1fr;
        }

        .demographic-grid {
          grid-template-columns: 1fr;
        }

        .vdot-table {
          min-width: 22rem;
        }

        .benchmark-table {
          min-width: 22rem;
        }

        .benchmark-chart {
          min-width: 36rem;
        }

        .benchmark-controls label {
          flex-basis: 100%;
        }
      }
    </style>
  </body>
</html>
