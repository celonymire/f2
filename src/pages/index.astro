---
import Navbar from "../components/Navbar.astro";
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Home</title>
  </head>
  <body>
    <header>
      <h1>Home Page</h1>
      <Navbar />
    </header>

    <main>
      <section>
        <h2>Welcome</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur
          tincidunt, nibh sed elementum faucibus, turpis risus dignissim lacus,
          quis ullamcorper metus lorem id massa.
        </p>
        <p>
          Integer feugiat, ligula in gravida consequat, nisl libero tempus est,
          et ultrices lacus velit a turpis. Aenean at condimentum orci. Sed
          pharetra elit eu vestibulum ultrices.
        </p>
      </section>

      <section>
        <h2>Highlights</h2>
        <ul>
          <li>Lorem ipsum dolor sit amet.</li>
          <li>Praesent commodo cursus magna.</li>
          <li>Vestibulum id ligula porta felis.</li>
          <li>Donec ullamcorper nulla non metus.</li>
        </ul>
      </section>
    </main>

    <style>
      body {
        font-family: sans-serif;
        line-height: 1.5;
        margin: 0;
        padding: 1.5rem;
      }

      header {
        margin-bottom: 1.5rem;
      }

      nav {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      main {
        display: grid;
        gap: 1.25rem;
      }
    </style>
  </body>
</html>
