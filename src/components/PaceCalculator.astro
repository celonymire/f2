---
const {
  title = "Pace Calculator",
  description = "Enter a distance in meters and a time in hh:mm:ss to calculate pace per mile and pace per kilometer.",
} = Astro.props;
---

<section class="pace-calculator" id="pace-calculator">
  <h2>{title}</h2>
  <p>{description}</p>

  <div class="pace-calculator-grid">
    <section>
      <h3>Inputs</h3>
      <form>
        <label>
          Common running distance
          <select id="distance-presets">
            <option value="400">400 m</option>
            <option value="800">800 m</option>
            <option value="1500">1500 m</option>
            <option value="3000">3000 m</option>
            <option value="5000">5K / 5000 m</option>
            <option value="10000">10K / 10000 m</option>
            <option value="21098.75">Half marathon / 21.1 km</option>
            <option value="42195">Marathon / 42.2 km</option>
            <option value="custom">Custom</option>
          </select>
        </label>

        <div id="custom-distance-field" hidden>
          <label>
            Custom distance (meters)
            <input
              id="distance"
              type="number"
              min="0"
              step="any"
              value="1000"
            />
          </label>
        </div>

        <div class="time-grid" aria-label="Time input">
          <label>
            Hours
            <input
              id="hours"
              type="number"
              min="0"
              max="59"
              step="1"
              value="1"
            />
          </label>
          <label>
            Minutes
            <input
              id="minutes"
              type="number"
              min="0"
              max="59"
              step="1"
              value="0"
            />
          </label>
          <label>
            Seconds
            <input
              id="seconds"
              type="number"
              min="0"
              max="59"
              step="1"
              value="0"
            />
          </label>
        </div>

        <div class="demographic-grid" aria-label="Demographic input">
          <label>
            Gender
            <select id="gender">
              <option value="male">Male</option>
              <option value="female">Female</option>
            </select>
          </label>
          <label>
            Age group
            <select id="age-group">
              <option value="10">10</option>
              <option value="15">15</option>
              <option value="20">20</option>
              <option value="25">25</option>
              <option value="30" selected>30</option>
              <option value="35">35</option>
              <option value="40">40</option>
              <option value="45">45</option>
              <option value="50">50</option>
              <option value="55">55</option>
              <option value="60">60</option>
              <option value="65">65</option>
              <option value="70">70</option>
              <option value="75">75</option>
              <option value="80">80</option>
              <option value="85">85</option>
              <option value="90">90</option>
            </select>
          </label>
        </div>
      </form>
    </section>

    <section>
      <h3>Results</h3>
      <dl class="results">
        <div>
          <dt>Pace per mile</dt>
          <dd id="pace-per-mile">00:00:00 / mi</dd>
        </div>
        <div>
          <dt>Pace per kilometer</dt>
          <dd id="pace-per-kilometer">00:00:00 / km</dd>
        </div>
        <div>
          <dt>Time</dt>
          <dd id="formatted-time">00:00:00</dd>
        </div>
        <div>
          <dt>Race rank</dt>
          <dd id="race-rank">Loading rank data...</dd>
        </div>
        <div>
          <dt>VDOT score</dt>
          <dd id="vdot-score">N/A</dd>
        </div>
        <div>
          <dt>VDOT level</dt>
          <dd id="vdot-level">N/A</dd>
        </div>
      </dl>
    </section>
  </div>
</section>

<style>
  .pace-calculator {
    display: grid;
    gap: 1rem;
  }

  .pace-calculator p {
    margin: 0;
  }

  .pace-calculator-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }

  form {
    display: grid;
    gap: 0.75rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
  }

  input,
  select {
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem;
  }

  .time-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .demographic-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .results {
    display: grid;
    gap: 1rem;
    margin: 0;
  }

  .results div {
    display: grid;
    gap: 0.25rem;
  }

  dt {
    font-size: 0.9rem;
    font-weight: 700;
  }

  dd {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .pace-calculator-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .time-grid {
      grid-template-columns: 1fr;
    }

    .demographic-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
