---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<nav>
  <a href={baseUrl}>Home</a>
  <a href={`${baseUrl}calculator`}>Calculator</a>
  <a href={`${baseUrl}map`}>Map</a>
  <a href={`${baseUrl}products`}>Products</a>
</nav>
